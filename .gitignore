# Python
venv/
.venv/
__pycache__/
*.pyc

# Build & Release
dist/
build/
release/
GNX_RELEASES/
installer_output/

# Runtime & Outputs
outputs/
temp*/
logs/
downloads/

# Secrets & API Keys
.env
.env.*
set_gemini.py
set_cloudinary.py
test_gemini.py
client_secret.json

# Binaries & Large Media
assets/ffmpeg/
*.exe
*.dll
*.zip
*.7z
*.mp4
*.mov
*.mkv
*.mp3
*.wav

# Wrangler / Cloudflare
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example

# Custom Sensitive Data
tokens/
data/tokens/
config/*.json
core/*.json
production_queue.json
_BACKUP_SYSTEM_LAMA/

# OS Generated
.DS_Store
Thumbs.db